<Window x:Class="WpfAppTest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfAppTest"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <!-- 画面を上下2分割する -->
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- 上半分：ボタン。押すとViewModelのPickCommandが実行される -->
        <Button Grid.Row="0" Content="好きな漫画" Command="{Binding PickCommand}"/>
        <!-- 下半分：結果表示ラベル。ViewModelのResultTextにバインドされている -->
        <Label Grid.Row="1" Content="{Binding ResultText}" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Center"/>
    </Grid>
</Window>
